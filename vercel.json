{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/mentions-legales", "destination": "/legal/mentions-legales", "permanent": true },
    { "source": "/conditions-generales", "destination": "/legal/conditions-generales", "permanent": true },
    { "source": "/politique-de-confidentialite", "destination": "/legal/politique-de-confidentialite", "permanent": true },
    { "source": "/politique-cookies", "destination": "/legal/politique-cookies", "permanent": true },
    { "source": "/avertissement-resultats", "destination": "/legal/avertissement-resultats", "permanent": true },
    { "source": "/cgv", "destination": "/legal/conditions-generales", "permanent": true },
    { "source": "/mentions", "destination": "/legal/mentions-legales", "permanent": true },
    { "source": "/confidentialite", "destination": "/legal/politique-de-confidentialite", "permanent": true },
    { "source": "/cookies", "destination": "/legal/politique-cookies", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; base-uri 'self'; form-action 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; frame-src https://app.iclosed.io; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/assets/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(css|js)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}
